---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1 class="post-title" id="top">{{ title }}</h1>
    <div class="post-meta">
      <time datetime="{{ date | formatDate }}">{{ date | formatDate }}</time>
      <span class="post-divider">·</span>
      <span class="post-reading-time">{{ content | readingTime }}</span>
    </div>
  </header>

  <div class="post-layout">
    <div class="post-content" id="post-content">
      <nav class="post-toc-inline" id="post-toc-inline" aria-label="文章目录"></nav>
      {{ content | videoShortcode | addHeadingIds | renumberFootnotes | safe }}
    </div>
    <aside class="post-side-notes" id="post-side-notes" aria-label="文章旁注"></aside>
  </div>

  <footer class="post-footer">
    <div class="post-tags">
      {% for tag in tags %}
        {% if tag != "post" %}
          <span class="tag">{{ tag }}</span>
        {% endif %}
      {% endfor %}
    </div>

    <div class="post-navigation">
      {% if collections.posts %}
        {% set posts = collections.posts | reverse %}
        {% for post in posts %}
          {% if post.url == page.url %}
            {% if loop.index > 1 %}
              {% set prevPost = posts[loop.index - 2] %}
              <a href="{{ prevPost.url }}" class="nav-link prev">&larr; {{ prevPost.data.title }}</a>
            {% endif %}
            {% if loop.index < posts.length %}
              {% set nextPost = posts[loop.index] %}
              <a href="{{ nextPost.url }}" class="nav-link next">{{ nextPost.data.title }} &rarr;</a>
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </footer>

  <section class="comments-section">
    <h2>评论</h2>
    <script src="https://giscus.app/client.js"
      data-repo="MrTang-Yuhan/my-webpage"
      data-repo-id="R_kgDOSW6hcA"
      data-category="General"
      data-category-id="DIC_kwDOSW6hcM4C8hH8"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="preferred_color_scheme"
      data-lang="zh-CN"
      crossorigin="anonymous"
      async>
    </script>
  </section>
</article>

<script src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/contrib/auto-render.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var content = document.getElementById('post-content');
  var sideNotes = document.getElementById('post-side-notes');
  var tocInline = document.getElementById('post-toc-inline');
  if (!content) return;

  if (typeof renderMathInElement === 'function') {
    renderMathInElement(content, {
      delimiters: [
        { left: '$$', right: '$$', display: true },
        { left: '$', right: '$', display: false }
      ],
      throwOnError: false
    });
  }

  if (tocInline) {
    const headings = content.querySelectorAll('h1, h2, h3, h4, h5');
    if (headings.length > 0) {
      const title = document.createElement('p');
      title.className = 'toc-inline-title';
      title.textContent = '目录';
      const nav = document.createElement('div');
      nav.className = 'toc-inline-nav';
      headings.forEach(function(heading) {
        if (!heading.id) return;
        const link = document.createElement('a');
        link.href = '#' + heading.id;
        link.className = 'toc-link toc-level-' + heading.tagName.toLowerCase();
        link.textContent = heading.textContent;
        nav.appendChild(link);
      });
      tocInline.appendChild(title);
      tocInline.appendChild(nav);
    } else {
      tocInline.remove();
    }
  }

  const footnoteById = {};
  const footnoteAnchors = new Map();
  const nearRefNotes = [];
  content.querySelectorAll('aside.footnote[id]').forEach(function(footnote) {
    footnoteById[footnote.id] = footnote;
  });

  const moved = new Set();
  content.querySelectorAll('sup.footnote-ref a[href^="#fn"]').forEach(function(link) {
    const href = link.getAttribute('href') || '';
    const targetId = href.replace('#', '');
    const footnote = footnoteById[targetId];
    if (!footnote || moved.has(targetId)) return;
    const anchorBlock = link.closest('p, li, blockquote, h1, h2, h3, h4, h5, h6');
    if (!anchorBlock || !anchorBlock.parentNode) return;
    footnote.classList.add('footnote-near-ref');
    footnote.dataset.anchorId = targetId;
    footnoteAnchors.set(targetId, anchorBlock);
    nearRefNotes.push(footnote);
    anchorBlock.parentNode.insertBefore(footnote, anchorBlock.nextSibling);
    moved.add(targetId);
  });

  content.querySelectorAll('aside.footnote').forEach(function(footnote, index) {
    if (footnote.querySelector('.footnote-number')) return;
    const badge = document.createElement('span');
    badge.className = 'footnote-number';
    badge.textContent = index + 1;
    footnote.insertBefore(badge, footnote.firstChild);
  });

  function isDesktopSideNotes() {
    return window.matchMedia('(min-width: 1180px)').matches;
  }

  function placeNotesInline() {
    if (!sideNotes) return;
    nearRefNotes.forEach(function(footnote) {
      const anchorId = footnote.dataset.anchorId;
      const anchorBlock = anchorId ? footnoteAnchors.get(anchorId) : null;
      if (anchorBlock && anchorBlock.parentNode) {
        anchorBlock.parentNode.insertBefore(footnote, anchorBlock.nextSibling);
        footnote.style.top = '';
      }
    });
  }

  function placeNotesInSideRail() {
    if (!sideNotes) return;
    const contentRect = content.getBoundingClientRect();
    let cursorTop = 0;
    const minGap = 16;

    nearRefNotes.forEach(function(footnote) {
      const anchorId = footnote.dataset.anchorId;
      const anchorBlock = anchorId ? footnoteAnchors.get(anchorId) : null;
      if (!anchorBlock) return;

      sideNotes.appendChild(footnote);
      footnote.style.top = '';

      const anchorRect = anchorBlock.getBoundingClientRect();
      const desiredTop = Math.max(0, Math.round(anchorRect.top - contentRect.top));
      const safeTop = Math.max(desiredTop, cursorTop);
      footnote.style.top = safeTop + 'px';
      cursorTop = safeTop + footnote.offsetHeight + minGap;
    });
  }

  function syncSideNotesLayout() {
    if (!sideNotes) return;
    if (isDesktopSideNotes()) {
      placeNotesInSideRail();
    } else {
      placeNotesInline();
    }
  }

  syncSideNotesLayout();
  window.addEventListener('resize', function() {
    syncSideNotesLayout();
  });
});
</script>
