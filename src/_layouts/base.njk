<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "My Blog" }}</title>
  <meta name="description" content="{{ description or 'A minimalist blog' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.css">
  <link rel="stylesheet" href="/css/style.css">
  {% block head %}{% endblock %}
</head>
<body>
  <div class="container">
    <header class="header">
      <nav class="nav">
        <a href="/" class="nav-logo">Blog</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/posts">Archive</a>
          <a href="/about">About</a>
          <a href="/admin">Write</a>
        </div>
        <button class="search-toggle" id="searchToggle" aria-label="Toggle search">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
      </nav>
      <div class="search-container" id="searchContainer">
        <input type="text" class="search-input" id="searchInput" placeholder="Search posts...">
        <div class="search-results" id="searchResults"></div>
      </div>
    </header>

    <main class="main">
      {{ content | safe }}
    </main>

    <footer class="footer">
      <div class="footer-content">
        <p>&copy; 2026 All rights reserved.</p>
        <div class="footer-links">
          <a href="https://github.com/MrTang-Yuhan" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="/rss.xml">RSS</a>
          <a href="/admin">Admin</a>
        </div>
      </div>
    </footer>
  </div>

  <script src="/js/main.js"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
