---
layout: base.njk
title: Archive
description: 全部文章
permalink: /posts/
---

<section class="archive-header">
  <h1 class="archive-title">归档</h1>
  {% set totalPosts = 0 %}
  {% for dir, posts in collections.postsByDir %}
    {% set totalPosts = totalPosts + posts | length %}
  {% endfor %}
  <p class="archive-subtitle">共 {{ totalPosts }} 篇文章</p>
</section>

{% for dir, posts in collections.postsByDir %}
  <section class="archive-section">
    <h2 class="archive-dir-title">{{ dir | replace("-", " ") | title }}</h2>
    <ul class="archive-list">
      {% for post in posts %}
        <li class="archive-list-item">
          <span class="archive-date">{{ post.date | formatDate }}</span>
          <span class="archive-title"><a href="{{ post.url }}">{{ post.data.title }}</a></span>
        </li>
      {% endfor %}
    </ul>
  </section>
{% endfor %}
