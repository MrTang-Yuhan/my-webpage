---
layout: base.njk
title: Home
description: A minimalist blog
---

<section class="hero">
  <h1 class="hero-title">唐宇涵的个人博客</h1>
  <p class="hero-subtitle">体系结构——权衡的艺术，性能的诗歌.</p>
</section>

<section class="post-list-section">
  <h2 style="font-size: 1.25rem; margin-bottom: 1.5rem; color: var(--color-text-secondary);">Recent Posts</h2>
  <ul class="post-list">
    {% set allPosts = [] %}
    {% for dir, posts in collections.postsByDir %}
      {% for post in posts %}
        {% set allPosts = allPosts.concat([post]) %}
      {% endfor %}
    {% endfor %}
    {% for post in allPosts | reverse %}
      <li class="post-list-item">
        <h3 class="post-list-title">
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h3>
        <div class="post-list-meta">
          <time datetime="{{ post.date | formatDate }}">{{ post.date | formatDate }}</time>
          <span class="post-divider">·</span>
          <span>{{ post.content | readingTime }}</span>
        </div>
        <p class="post-list-excerpt">{{ post.data.description or post.content | truncate(150) }}</p>
      </li>
    {% endfor %}
  </ul>
</section>
